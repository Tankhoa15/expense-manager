# Production Environment Variables
# Copy to .env.prod and fill in real values — NEVER commit .env.prod to git

# Database
DB_USERNAME=postgres
DB_PASSWORD=your_very_strong_prod_password

# Redis
REDIS_PASSWORD=your_very_strong_redis_password

# JWT (generate: openssl rand -base64 64)
JWT_SECRET=replace_with_a_very_long_random_secret_at_least_64_chars_for_production

# Email (Gmail App Password)
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your_gmail_app_password
MAIL_FROM=noreply@expense-manager.com
